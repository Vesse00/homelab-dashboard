// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url       = env("DATABASE_URL")
}

model ContainerStat {
  id          Int      @id @default(autoincrement())
  containerId String
  name        String
  state       String   // np. "running", "exited"
  status      String   // np. "Up 2 hours"
  cpu         Float?   // opcjonalnie: użycie procka (dodamy później)
  memory      Float?   // opcjonalnie: użycie ramu
  createdAt   DateTime @default(now())
  
  // Indeks przyspieszy wyszukiwanie historii dla konkretnego kontenera
  @@index([containerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @map("refreshToken") // Dla Google
  access_token      String? @map("accessToken")  // Dla Google
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  dashboardLayout String? // JSON string z układem dashboardu
  backgroundUrl   String? // URL tła dashboardu
  discoveredServices String? // JSON string z listą odkrytych usług
  password      String?   // Dla logowania hasłem (opcjonalne, bo Google tego nie ma)
  role          String    @default("USER") // "ADMIN" lub "USER"
  createdAt     DateTime  @default(now())

  // --- NOWE POLA DO 2FA ---
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  // --- Relacje ---
  accounts      Account[]
  sessions      Session[]
  kiosks         Kiosk[]   
  
  // Tu możesz dodać relacje do kontenerów jeśli chcesz przypisywać kontenery do userów
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model SystemSettings {
  id                  String   @id @default("global")
  registrationEnabled Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  containerId String? //(Unikalny ID z Dockera)
  name        String
  type        String   @default("generic") // np. pihole, docker_stats
  protocol    String   @default("http")    // http lub https
  ip          String
  port        Int
  publicUrl   String?  // np. portainer.local
  icon        String   @default("Box")
  
  // Autoryzacja
  authType    String   @default("none") // none, basic, apikey
  username    String?
  password    String?
  apiKey      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Kiosk {
  id           String   @id @default(cuid())
  name         String   // np. "Tablet w Kuchni"
  pairingCode  String?  @unique // Tymczasowy 8-cyfrowy kod (np. "48291034")
  deviceToken  String?  @unique // Bezpieczny token sesji dla tabletu
  layout       String?  // Zapisany układ kafelków tylko dla tego tabletu (JSON)
  tabId        String?  // (Opcjonalnie) ID zakładki z głównego panelu, z której pochodzi układ
  
  // Relacja - kto przypisał i skonfigurował ten kiosk
  userId       String?  
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}