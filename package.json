{
  "name": "homelab-dashboard",
  "version": "0.1.0-beta",
  "private": true,
  "scripts": {
    "dev:next": "next dev -p 3003",
    "dev:terminal": "node terminal-server.mjs",
    "dev": "concurrently -c \"cyan.bold,magenta.bold\" -n \"NEXT,TERM\" \"npm run dev:next\" \"npm run dev:terminal\"",
    "build": "next build",
    "start:next": "next start -p 3004",
    "start:terminal": "node terminal-server.mjs",
    "start": "concurrently -c \"cyan.bold,magenta.bold\" -n \"NEXT,TERM\" \"npm run start:next\" \"npm run start:terminal\"",
    "lint": "eslint",
    "prisma:generate": "prisma generate"
  },
