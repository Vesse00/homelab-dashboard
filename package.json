    "date-fns": "^4.1.0",
    "dockerode": "^4.0.9",
    "framer-motion": "^12.34.1",
    "lucide-react": "^0.574.0",
    "next": "16.2.2",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "node-disk-info": "^1.3.0",
    "node-pty": "^1.1.0",
    "nodemailer": "^8.0.4",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
